    """Health check endpoint — DB status + collector status."""
    from dashboard.db import health_check as db_health
    db_results = db_health()
    return jsonify({
        "status":     "ok" if all(db_results.values()) else "degraded",
        "db":         db_results,
        "collector":  _COLLECTOR_AVAILABLE,
